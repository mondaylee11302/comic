# Stage-2 Volc (Ark) multimodal embedding
VOLC_API_KEY=
VOLC_MODEL_ENDPOINT=
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_MM_PROMPT_TEXT=图像内容语义表示

# Volc OCRPdf (minimal required when PSD has no text layers)
VOLC_OCR_ENABLE=0
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# Optional session token (STS)
VOLC_OCR_SESSION_TOKEN=

# OCR endpoint/timeout
VOLC_OCR_HOST=visual.volcengineapi.com
VOLC_OCR_MAX_RETRIES=2
VOLC_OCR_CONNECT_TIMEOUT_SEC=8
VOLC_OCR_READ_TIMEOUT_SEC=30

# OCRPdf request options
VOLC_OCR_VERSION=v3
VOLC_OCR_PARSE_MODE=auto
VOLC_OCR_TABLE_MODE=markdown
VOLC_OCR_FILTER_HEADER=true
VOLC_OCR_PAGE_START=0
VOLC_OCR_PAGE_NUM=16
VOLC_OCR_API_MODE=pdf
VOLC_OCR_LANG=zh

# MultiLanguageOCR optional request options
VOLC_OCR_MULTILANG_MODE=default
VOLC_OCR_MULTILANG_FILTER_THRESH=80
VOLC_OCR_MULTILANG_APPROXIMATE_PIXEL=0

# Base64(urlencode) budget (default 8MB)
VOLC_OCR_MAX_URLENCODED_BASE64_BYTES=8388608

# Optional when using data_type=uri(object_key) in volc_imagex.ocr.ocr_ai_process
VOLC_OCR_PUBLIC_DOMAIN=
